generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Size {
  S
  M
  L
  XL
  XXL
  XXXL
}

enum Gender {
  men
  women
  kid
  unisex
}

model Category {
  id      String    @id @default(uuid())
  name    String    @unique
  Product Product[]
}

model Product {
  description String
  id          String   @id @default(uuid())
  inStock     Int
  price       Float    @default(0)
  size        Size[]   @default([])
  slug        String   @unique
  tags        String[] @default([])
  title       String
  gender      Gender

  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    String
  productImages ProductImage[]

  @@index([gender])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  product   Product @relation(fields: [productId], references: [id])
  productId String
}
