{
  "name": "for-fun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:turbo": "next dev",
    "dev": "next dev --webpack",
    "build": "npm run prisma:deploy && next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "node scripts/run-playwright-with-coverage.mjs",
    "test:e2e:coverage:report": "node scripts/generate-playwright-coverage-report.mjs",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint",
    "lint:commit": "commitlint --from HEAD~1 --to HEAD",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "seed": "tsx src/seed/seed-database.ts",
    "prisma:deploy": "npx prisma migrate deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@paypal/react-paypal-js": "^8.1.3",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "swiper": "^12.1.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
